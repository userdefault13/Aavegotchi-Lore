# API port (default 3004)
PORT=3004

# MongoDB
MONGODB_URI=mongodb://localhost:27017/gotchi-lore
MONGO_DB_NAME=gotchi-lore

# JWT for wallet auth (SIWE). In production set AUTH_STRICT=1
JWT_SECRET=change-me-in-production
AUTH_STRICT=0

# SIWE message domain (defaults: localhost / http://localhost:5174)
SIWE_DOMAIN=localhost
SIWE_URI=http://localhost:5174

# DAO canonical lore (seed-canon-world.mjs)
CANON_OWNER_WALLET=0x0000000000000000000000000000000000000001
CANON_SLUG=gotchiverse-canon
CANON_TITLE=Gotchiverse Canon

# Snapshot governance (Phase 4)
SNAPSHOT_SPACE=
SNAPSHOT_HUB_URL=https://hub.snapshot.org/graphql
SNAPSHOT_RELAXED=0

# Vite dev server port (default 5174)
VITE_DEV_PORT=5174

# Vite
VITE_API_BASE=

# Base / Aavegotchi subgraph (Phase 7 imports)
VITE_ALCHEMY_API_KEY=
